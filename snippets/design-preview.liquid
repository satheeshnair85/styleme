{% comment %}
  Design Preview Component (Step 4)
  Displays the selected design overlaid on the chosen product mockup with
  accurate print area positioning, pinch-to-zoom for mobile, pricing summary,
  and add-to-cart / navigation controls.
  Requirements: 7.2, 7.3, 7.4, 7.5, 7.7, 7.9, 7.10, 22.7, 25.2, 25.3, 25.5, 25.6, 25.7, 25.10
{% endcomment %}

<div class="design-preview" id="design-preview">
  <!-- Loading State -->
  <div class="design-preview__loading" id="dp-loading" hidden>
    <div class="design-preview__spinner">
      <svg class="design-preview__spinner-icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/>
      </svg>
    </div>
    <h3 class="design-preview__loading-title">Preparing Your Preview...</h3>
    <p class="design-preview__loading-text">Applying your design to the product</p>
  </div>

  <!-- Error State -->
  <div class="design-preview__error" id="dp-error" hidden>
    <div class="design-preview__error-icon">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
    </div>
    <h3 class="design-preview__error-title" id="dp-error-title">Preview Failed</h3>
    <p class="design-preview__error-text" id="dp-error-message">Something went wrong while preparing your preview.</p>
    <button type="button" class="btn btn-primary design-preview__retry-btn" id="dp-retry-btn">
      Try Again
    </button>
  </div>

  <!-- Preview Content -->
  <div class="design-preview__content" id="dp-content" hidden>
    <h2 class="design-preview__title">Your Custom Product</h2>
    <p class="design-preview__subtitle">Pinch to zoom on mobile for a closer look</p>

    <div class="design-preview__layout">
      <!-- Mockup Area -->
      <div class="design-preview__mockup-area">
        <div class="design-preview__zoom-container" id="dp-zoom-container">
          <div class="design-preview__mockup" id="dp-mockup" role="img" aria-label="Product mockup with your design">
            <!-- Product shape background -->
            <div class="design-preview__product-shape" id="dp-product-shape"></div>
            <!-- Design overlay positioned in print area -->
            <div class="design-preview__design-overlay" id="dp-design-overlay">
              <img class="design-preview__design-image" id="dp-design-image" src="" alt="Your custom design" draggable="false" width="400" height="400" decoding="async">
            </div>
          </div>
        </div>
        <p class="design-preview__zoom-hint" id="dp-zoom-hint">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
          </svg>
          Pinch to zoom &middot; Double-tap to reset
        </p>
      </div>

      <!-- Product Info Panel -->
      <div class="design-preview__info-panel">
        <div class="design-preview__product-summary">
          <h3 class="design-preview__product-name" id="dp-product-name"></h3>
          <div class="design-preview__variant-info">
            <span class="design-preview__color-swatch" id="dp-color-swatch"></span>
            <span class="design-preview__variant-text" id="dp-variant-text"></span>
          </div>
          <p class="design-preview__material" id="dp-material"></p>
        </div>

        <!-- Print Specifications -->
        <div class="design-preview__specs">
          <h4 class="design-preview__specs-title">Print Specifications</h4>
          <div class="design-preview__spec-row">
            <span>Print Area</span>
            <span id="dp-spec-area"></span>
          </div>
          <div class="design-preview__spec-row">
            <span>Position</span>
            <span id="dp-spec-position"></span>
          </div>
          <div class="design-preview__spec-row">
            <span>Resolution</span>
            <span id="dp-spec-dpi"></span>
          </div>
          <div class="design-preview__spec-row">
            <span>Color Mode</span>
            <span id="dp-spec-color"></span>
          </div>
        </div>

        <!-- Delivery Estimate -->
        <div class="design-preview__delivery">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
            <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          <span id="dp-delivery">Estimated delivery: 2-5 business days</span>
        </div>

        <!-- Pricing -->
        <div class="design-preview__pricing">
          <div class="design-preview__price-row">
            <span>Base price</span><span id="dp-base-price"></span>
          </div>
          <div class="design-preview__price-row">
            <span>AI Design fee</span><span id="dp-design-fee"></span>
          </div>
          <div class="design-preview__price-row design-preview__price-row--total">
            <span>Total</span><span id="dp-total-price"></span>
          </div>
        </div>

        <!-- Validation Notice -->
        <div class="design-preview__validation" id="dp-validation" hidden>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <span id="dp-validation-text">Design meets all print requirements</span>
        </div>

        <!-- Action Buttons -->
        <div class="design-preview__actions">
          <button type="button" class="btn btn-primary design-preview__add-to-cart" id="dp-add-to-cart">
            Add to Cart
          </button>
          <div class="design-preview__secondary-actions">
            <button type="button" class="btn btn-secondary design-preview__back-btn" id="dp-change-design">
              ← Change Design
            </button>
            <button type="button" class="btn btn-secondary design-preview__back-btn" id="dp-change-product">
              ← Change Product
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ── Design Preview ── */
  .design-preview { max-width: 1200px; margin: 0 auto; padding: 1rem 0; }

  /* ── Loading State ── */
  .design-preview__loading { text-align: center; padding: 4rem 2rem; }
  .design-preview__spinner { display: inline-block; margin-bottom: 1.5rem; }
  .design-preview__spinner-icon {
    color: rgb(var(--color-base-accent-1, 99, 102, 241));
    animation: dp-spin 2s linear infinite;
  }
  @keyframes dp-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .design-preview__loading-title {
    font-size: 1.5rem; font-weight: 600;
    color: rgb(var(--color-base-text, 31, 41, 55)); margin-bottom: 0.5rem;
  }
  .design-preview__loading-text {
    font-size: 1rem; color: rgb(var(--color-base-text, 31, 41, 55), 0.7);
  }

  /* ── Error State ── */
  .design-preview__error { text-align: center; padding: 4rem 2rem; }
  .design-preview__error-icon { color: #ef4444; margin-bottom: 1rem; }
  .design-preview__error-title {
    font-size: 1.5rem; font-weight: 600;
    color: rgb(var(--color-base-text, 31, 41, 55)); margin-bottom: 0.5rem;
  }
  .design-preview__error-text {
    font-size: 1rem; color: rgb(var(--color-base-text, 31, 41, 55), 0.7);
    margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto;
  }

  /* ── Content Layout ── */
  .design-preview__content { padding: 1rem; }
  .design-preview__title {
    font-size: 2rem; font-weight: 700; text-align: center;
    color: rgb(var(--color-base-text, 31, 41, 55)); margin-bottom: 0.25rem;
  }
  .design-preview__subtitle {
    font-size: 0.9375rem; text-align: center;
    color: rgb(var(--color-base-text, 31, 41, 55), 0.6); margin-bottom: 2rem;
  }
  .design-preview__layout {
    display: grid; grid-template-columns: 1fr; gap: 2rem;
  }
  @media (min-width: 750px) {
    .design-preview__layout { grid-template-columns: 1fr 1fr; gap: 3rem; }
  }

  /* ── Mockup Area ── */
  .design-preview__mockup-area { display: flex; flex-direction: column; align-items: center; }
  .design-preview__zoom-container {
    width: 100%; max-width: 480px; touch-action: none;
    overflow: hidden; border-radius: 12px;
    background: rgb(var(--color-base-background-2, 249, 250, 251));
    border: 2px solid rgb(var(--color-base-text, 31, 41, 55), 0.08);
  }
  .design-preview__mockup {
    position: relative; width: 100%; aspect-ratio: 3/4;
    display: flex; align-items: center; justify-content: center;
    transform-origin: center center;
    transition: transform 0.1s ease-out;
  }
  .design-preview__mockup--mug { aspect-ratio: 4/3; }
  .design-preview__mockup--sticker { aspect-ratio: 1; }
  .design-preview__mockup--cap { aspect-ratio: 4/3; }

  /* ── Product Shape (CSS-rendered mockup) ── */
  .design-preview__product-shape {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
  }
  /* T-shirt / Polo shape */
  .design-preview__product-shape--tshirt {
    background: var(--dp-product-color, #333);
    clip-path: polygon(
      30% 0%, 70% 0%, 72% 8%, 100% 15%, 95% 35%, 80% 30%,
      82% 100%, 18% 100%, 20% 30%, 5% 35%, 0% 15%, 28% 8%
    );
  }
  .design-preview__product-shape--polo {
    background: var(--dp-product-color, #333);
    clip-path: polygon(
      30% 0%, 42% 0%, 50% 6%, 58% 0%, 70% 0%, 72% 8%, 100% 15%, 95% 35%, 80% 30%,
      82% 100%, 18% 100%, 20% 30%, 5% 35%, 0% 15%, 28% 8%
    );
  }
  /* Mug shape */
  .design-preview__product-shape--mug {
    background: var(--dp-product-color, #fff);
    border-radius: 4px 4px 12px 12px;
    width: 60%; height: 70%; position: absolute;
    top: 15%; left: 15%;
    box-shadow: inset 0 0 0 3px rgba(0,0,0,0.08);
  }
  .design-preview__product-shape--mug::after {
    content: ''; position: absolute; right: -18%; top: 20%;
    width: 18%; height: 40%; border: 4px solid var(--dp-product-color, #fff);
    border-left: none; border-radius: 0 12px 12px 0;
    box-shadow: 2px 0 0 rgba(0,0,0,0.08);
  }
  /* Cap shape */
  .design-preview__product-shape--cap {
    background: var(--dp-product-color, #333);
    width: 70%; height: 55%; position: absolute;
    top: 20%; left: 15%;
    border-radius: 50% 50% 5% 5%;
  }
  .design-preview__product-shape--cap::after {
    content: ''; position: absolute; bottom: -12%; left: 5%;
    width: 90%; height: 20%;
    background: var(--dp-product-color, #333);
    border-radius: 0 0 8px 8px;
    filter: brightness(0.85);
  }
  /* Sticker shape */
  .design-preview__product-shape--sticker {
    background: #fff; width: 75%; height: 75%;
    position: absolute; top: 12.5%; left: 12.5%;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.12), 0 0 0 1px rgba(0,0,0,0.06);
  }

  /* ── Design Overlay ── */
  .design-preview__design-overlay {
    position: absolute; display: flex; align-items: center; justify-content: center;
    overflow: hidden; border-radius: 4px;
  }
  .design-preview__design-image {
    width: 100%; height: 100%; object-fit: contain;
    user-select: none; -webkit-user-select: none;
    pointer-events: none;
  }

  /* ── Zoom Hint ── */
  .design-preview__zoom-hint {
    display: none; align-items: center; gap: 0.375rem;
    font-size: 0.8125rem; color: rgb(var(--color-base-text, 31, 41, 55), 0.45);
    margin-top: 0.75rem;
  }
  @media (pointer: coarse) {
    .design-preview__zoom-hint { display: flex; }
  }

  /* ── Info Panel ── */
  .design-preview__info-panel { display: flex; flex-direction: column; gap: 1.25rem; }
  .design-preview__product-name {
    font-size: 1.5rem; font-weight: 700; margin: 0 0 0.5rem;
    color: rgb(var(--color-base-text, 31, 41, 55));
  }
  .design-preview__variant-info {
    display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.25rem;
  }
  .design-preview__color-swatch {
    display: inline-block; width: 20px; height: 20px; border-radius: 50%;
    border: 2px solid rgba(0,0,0,0.12);
  }
  .design-preview__variant-text {
    font-size: 0.9375rem; color: rgb(var(--color-base-text, 31, 41, 55), 0.7);
  }
  .design-preview__material {
    font-size: 0.8125rem; color: rgb(var(--color-base-text, 31, 41, 55), 0.55); margin: 0;
  }

  /* ── Specs ── */
  .design-preview__specs {
    background: rgb(var(--color-base-background-2, 249, 250, 251));
    border-radius: 8px; padding: 1rem;
  }
  .design-preview__specs-title {
    font-size: 0.875rem; font-weight: 600; margin: 0 0 0.5rem;
    color: rgb(var(--color-base-text, 31, 41, 55));
  }
  .design-preview__spec-row {
    display: flex; justify-content: space-between; font-size: 0.8125rem;
    padding: 0.25rem 0; color: rgb(var(--color-base-text, 31, 41, 55), 0.65);
  }

  /* ── Delivery ── */
  .design-preview__delivery {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8125rem; color: rgb(var(--color-base-text, 31, 41, 55), 0.6);
  }

  /* ── Pricing ── */
  .design-preview__pricing {
    background: rgb(var(--color-base-background-2, 249, 250, 251));
    border-radius: 8px; padding: 0.75rem 1rem;
  }
  .design-preview__price-row {
    display: flex; justify-content: space-between; font-size: 0.875rem;
    padding: 0.25rem 0; color: rgb(var(--color-base-text, 31, 41, 55), 0.7);
  }
  .design-preview__price-row--total {
    font-weight: 700; font-size: 1.0625rem;
    border-top: 1px solid rgb(var(--color-base-text, 31, 41, 55), 0.1);
    padding-top: 0.5rem; margin-top: 0.25rem;
    color: rgb(var(--color-base-text, 31, 41, 55));
  }

  /* ── Validation ── */
  .design-preview__validation {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8125rem; color: #16a34a;
    background: #f0fdf4; border-radius: 8px; padding: 0.625rem 1rem;
  }
  .design-preview__validation--warning { color: #d97706; background: #fffbeb; }

  /* ── Actions ── */
  .design-preview__actions { display: flex; flex-direction: column; gap: 0.75rem; }
  .design-preview__add-to-cart {
    width: 100%; min-height: 52px; font-size: 1.0625rem; font-weight: 600;
  }
  .design-preview__secondary-actions { display: flex; gap: 0.5rem; }
  .design-preview__back-btn { flex: 1; min-height: 44px; font-size: 0.875rem; }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    .design-preview__title { font-size: 1.5rem; }
    .design-preview__product-name { font-size: 1.25rem; }
    .design-preview__secondary-actions { flex-direction: column; }
    .design-preview__back-btn { flex: none; }
  }

  /* ── Touch targets ── */
  @media (pointer: coarse) {
    .design-preview__add-to-cart { min-height: 56px; }
    .design-preview__back-btn { min-height: 48px; }
    .design-preview__retry-btn { min-height: 48px; }
  }
</style>
