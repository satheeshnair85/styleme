# Shopify Configuration
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your-access-token
SHOPIFY_API_KEY=your-api-key
SHOPIFY_API_SECRET=your-api-secret
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
BEDROCK_MODEL_ID=amazon.titan-image-generator-v2:0

# S3 Configuration
S3_BUCKET_NAME=custom-designs-bucket
S3_REGION=us-east-1

# Qikink Configuration
QIKINK_API_URL=https://api.qikink.com/v1
QIKINK_API_KEY=your-qikink-api-key
QIKINK_API_SECRET=your-qikink-secret

# Application Configuration
NODE_ENV=development
API_BASE_URL=https://your-api-gateway-url.amazonaws.com/dev
DESIGN_GENERATION_TIMEOUT=60000
MAX_DESIGN_VARIATIONS=3

# Production Configuration (set these for production deployments)
# SNS_ALERT_EMAIL=ops-team@your-domain.com
# CLOUDWATCH_DASHBOARD_NAME=ai-merchandise-production
# ENABLE_XRAY_TRACING=true