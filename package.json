{
  "name": "ai-custom-merchandise-platform",
  "version": "1.0.0",
  "description": "AI-powered custom merchandise e-commerce platform on Shopify",
  "main": "index.js",
  "scripts": {
    "dev": "shopify theme dev --store=stylemytravel-dev.myshopify.com",
    "build": "npm run build:theme && npm run build:lambda",
    "build:theme": "shopify theme package",
    "build:lambda": "cd backend && npm run build",
    "deploy": "npm run deploy:theme && npm run deploy:lambda",
    "deploy:theme": "shopify theme push --store=stylemytravel-dev.myshopify.com",
    "deploy:lambda": "cd backend && serverless deploy",
    "test": "jest",
    "test:integration": "jest --config=jest.integration.config.js",
    "lint": "eslint . --ext .js,.ts,.liquid",
    "format": "prettier --write ."
  },
  "keywords": [
    "shopify",
    "ai",
    "custom-merchandise",
    "bedrock",
    "qikink",
    "ecommerce"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@shopify/cli": "^3.50.0",
    "@shopify/theme": "^3.50.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}