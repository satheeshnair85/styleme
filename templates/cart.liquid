{% comment %}
  Cart Template
  Displays cart items with design thumbnails from line item properties.
  Handles quantity updates while preserving design metadata associations.
  Requirements: 9.1, 9.2, 9.3, 9.5
{% endcomment %}

<div class="cart-page">
  <div class="container">
    <h1 class="cart-page__title">Your Cart</h1>

    {% if cart.item_count == 0 %}
      <div class="cart-page__empty">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
        </svg>
        <h2>Your cart is empty</h2>
        <p>Start creating custom designs to add products to your cart.</p>
        <a href="/pages/customize" class="btn btn-primary">Start Customizing</a>
      </div>
    {% else %}
      <div class="cart-page__layout">
        <!-- Cart Items -->
        <div class="cart-page__items">
          {% for item in cart.items %}
            {% assign design_thumbnail = item.properties['_design_thumbnail'] %}
            {% assign design_url = item.properties['_design_url'] %}
            {% assign product_sku = item.properties['_product_sku'] %}
            {% assign variant_sku = item.properties['_variant_sku'] %}
            {% assign product_category = item.properties['_product_category'] %}
            {% assign item_color = item.properties['_color'] %}
            {% assign item_color_hex = item.properties['_color_hex'] %}
            {% assign item_size = item.properties['_size'] %}
            {% assign print_position = item.properties['_print_position'] %}
            {% assign print_dpi = item.properties['_print_dpi'] %}
            {% assign is_custom_design = false %}
            {% if design_url != blank %}
              {% assign is_custom_design = true %}
            {% endif %}

            <div class="cart-item" data-line-key="{{ item.key }}">
              <!-- Design Thumbnail -->
              <div class="cart-item__image">
                {% if is_custom_design and design_thumbnail != blank %}
                  <img
                    src="{{ design_thumbnail }}"
                    alt="Custom design for {{ item.product.title }}"
                    class="cart-item__design-thumb"
                    loading="lazy"
                    width="120"
                    height="120"
                  >
                  <span class="cart-item__custom-badge">AI Design</span>
                {% elsif item.image %}
                  <img
                    src="{{ item.image | image_url: width: 240 }}"
                    alt="{{ item.image.alt | escape }}"
                    loading="lazy"
                    width="120"
                    height="120"
                  >
                {% else %}
                  <div class="cart-item__placeholder">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                {% endif %}
              </div>

              <!-- Item Details -->
              <div class="cart-item__details">
                <h3 class="cart-item__name">{{ item.product.title }}</h3>

                {% if is_custom_design %}
                  <div class="cart-item__custom-info">
                    {% if product_category != blank %}
                      <span class="cart-item__meta">{{ item.properties['Product Type'] }}</span>
                    {% endif %}
                    {% if item_color != blank %}
                      <span class="cart-item__meta">
                        {% if item_color_hex != blank %}
                          <span class="cart-item__color-dot" style="background-color: {{ item_color_hex }}"></span>
                        {% endif %}
                        {{ item_color }}
                      </span>
                    {% endif %}
                    {% if item_size != blank %}
                      <span class="cart-item__meta">Size: {{ item_size }}</span>
                    {% endif %}
                  </div>

                  <div class="cart-item__print-specs">
                    <span>Print: {{ print_position | capitalize | default: 'Front' }}</span>
                    <span>&middot;</span>
                    <span>{{ print_dpi | default: '300' }} DPI</span>
                  </div>
                {% else %}
                  {% if item.variant.title != 'Default Title' %}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {% endif %}
                {% endif %}

                <!-- Visible line item properties (non-underscore prefixed) -->
                {% for property in item.properties %}
                  {% assign first_char = property.first | slice: 0 %}
                  {% if first_char != '_' and property.last != blank %}
                    {%- comment -%} Already displayed above for custom designs {%- endcomment -%}
                    {% unless is_custom_design and property.first == 'Design' or property.first == 'Color' or property.first == 'Size' or property.first == 'Product Type' %}
                      <p class="cart-item__property">
                        <span class="cart-item__property-name">{{ property.first }}:</span>
                        {{ property.last }}
                      </p>
                    {% endunless %}
                  {% endif %}
                {% endfor %}

                <div class="cart-item__price-mobile">
                  {{ item.final_line_price | money }}
                </div>
              </div>

              <!-- Quantity Controls -->
              <div class="cart-item__quantity">
                <label class="visually-hidden" for="qty-{{ item.key }}">Quantity</label>
                <div class="cart-item__qty-controls">
                  <button
                    type="button"
                    class="cart-item__qty-btn"
                    data-cart-qty-btn="-1"
                    data-line-key="{{ item.key }}"
                    aria-label="Decrease quantity"
                  >−</button>
                  <input
                    type="number"
                    id="qty-{{ item.key }}"
                    class="cart-item__qty-input"
                    value="{{ item.quantity }}"
                    min="0"
                    max="99"
                    data-cart-qty-input
                    data-line-key="{{ item.key }}"
                    aria-label="Quantity for {{ item.product.title }}"
                  >
                  <button
                    type="button"
                    class="cart-item__qty-btn"
                    data-cart-qty-btn="1"
                    data-line-key="{{ item.key }}"
                    aria-label="Increase quantity"
                  >+</button>
                </div>
                <button
                  type="button"
                  class="cart-item__remove"
                  data-cart-remove
                  data-line-key="{{ item.key }}"
                  aria-label="Remove {{ item.product.title }}"
                >
                  Remove
                </button>
              </div>

              <!-- Line Price -->
              <div class="cart-item__price">
                {{ item.final_line_price | money }}
              </div>
            </div>
          {% endfor %}
        </div>

        <!-- Cart Summary -->
        <div class="cart-page__summary">
          <h2 class="cart-summary__title">Order Summary</h2>

          <div class="cart-summary__row">
            <span>Subtotal ({{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }})</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <div class="cart-summary__row cart-summary__row--muted">
            <span>Shipping</span>
            <span>Calculated at checkout</span>
          </div>

          <div class="cart-summary__row cart-summary__row--total">
            <span>Estimated Total</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <form action="/checkout" method="post" class="cart-summary__checkout" id="cart-checkout-form">
            {% comment %}
              Store design S3 URLs in cart note for fulfillment reference (Req 10.3).
              The note is built from line item properties and set as a hidden field.
            {% endcomment %}
            <textarea name="note" id="cart-design-note" class="visually-hidden" aria-hidden="true">
              {%- for item in cart.items -%}
                {%- assign d_url = item.properties['_design_url'] -%}
                {%- if d_url != blank -%}
Design for {{ item.product.title }} (Line {{ item.key | truncate: 8, '' }}): {{ d_url }}
                {%- endif -%}
              {%- endfor -%}
            </textarea>
            <button type="submit" class="btn btn-primary cart-summary__checkout-btn">
              Proceed to Checkout
            </button>
          </form>

          <a href="/pages/customize" class="cart-summary__continue">
            ← Continue Customizing
          </a>
        </div>
      </div>
    {% endif %}
  </div>
</div>

<style>
  /* ── Cart Page Layout ── */
  .cart-page { padding: 2rem 0 4rem; min-height: 60vh; }
  .cart-page__title {
    font-size: 2rem; font-weight: 700; margin-bottom: 2rem;
    color: rgb(var(--color-base-text, 31, 41, 55));
  }

  /* ── Empty State ── */
  .cart-page__empty {
    text-align: center; padding: 4rem 2rem;
    color: rgb(var(--color-base-text, 31, 41, 55), 0.6);
  }
  .cart-page__empty svg { margin-bottom: 1.5rem; opacity: 0.4; }
  .cart-page__empty h2 {
    font-size: 1.5rem; font-weight: 600; margin-bottom: 0.5rem;
    color: rgb(var(--color-base-text, 31, 41, 55));
  }
  .cart-page__empty p { margin-bottom: 2rem; }
  .cart-page__empty .btn { display: inline-block; }

  /* ── Cart Layout (items + summary) ── */
  .cart-page__layout {
    display: grid; grid-template-columns: 1fr; gap: 2rem;
  }
  @media (min-width: 900px) {
    .cart-page__layout { grid-template-columns: 1fr 360px; gap: 3rem; align-items: start; }
  }

  /* ── Cart Item ── */
  .cart-item {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgb(var(--color-base-text, 31, 41, 55), 0.08);
  }
  @media (min-width: 750px) {
    .cart-item { grid-template-columns: 120px 1fr auto auto; }
  }

  /* ── Item Image ── */
  .cart-item__image {
    position: relative; width: 100px; height: 100px;
    border-radius: 8px; overflow: hidden;
    background: rgb(var(--color-base-background-2, 249, 250, 251));
    border: 1px solid rgb(var(--color-base-text, 31, 41, 55), 0.08);
  }
  @media (min-width: 750px) {
    .cart-item__image { width: 120px; height: 120px; }
  }
  .cart-item__design-thumb {
    width: 100%; height: 100%; object-fit: contain; padding: 4px;
  }
  .cart-item__custom-badge {
    position: absolute; top: 4px; left: 4px;
    background: rgb(var(--color-base-accent-1, 99, 102, 241));
    color: #fff; font-size: 0.625rem; font-weight: 600;
    padding: 2px 6px; border-radius: 4px; text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .cart-item__placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    color: rgb(var(--color-base-text, 31, 41, 55), 0.25);
  }

  /* ── Item Details ── */
  .cart-item__details { min-width: 0; }
  .cart-item__name {
    font-size: 1rem; font-weight: 600; margin: 0 0 0.25rem;
    color: rgb(var(--color-base-text, 31, 41, 55));
  }
  .cart-item__custom-info {
    display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.25rem;
  }
  .cart-item__meta {
    display: inline-flex; align-items: center; gap: 0.25rem;
    font-size: 0.8125rem; color: rgb(var(--color-base-text, 31, 41, 55), 0.65);
  }
  .cart-item__color-dot {
    display: inline-block; width: 12px; height: 12px; border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.15);
  }
  .cart-item__print-specs {
    display: flex; gap: 0.375rem; font-size: 0.75rem;
    color: rgb(var(--color-base-text, 31, 41, 55), 0.45);
    margin-bottom: 0.25rem;
  }
  .cart-item__variant {
    font-size: 0.8125rem; color: rgb(var(--color-base-text, 31, 41, 55), 0.6);
    margin: 0 0 0.25rem;
  }
  .cart-item__property {
    font-size: 0.8125rem; color: rgb(var(--color-base-text, 31, 41, 55), 0.6);
    margin: 0;
  }
  .cart-item__property-name { font-weight: 500; }
  .cart-item__price-mobile {
    display: block; font-weight: 600; margin-top: 0.5rem;
    color: rgb(var(--color-base-text, 31, 41, 55));
  }
  @media (min-width: 750px) {
    .cart-item__price-mobile { display: none; }
  }

  /* ── Quantity Controls ── */
  .cart-item__quantity {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  }
  .cart-item__qty-controls {
    display: flex; align-items: center;
    border: 1px solid rgb(var(--color-base-text, 31, 41, 55), 0.15);
    border-radius: 6px; overflow: hidden;
  }
  .cart-item__qty-btn {
    width: 36px; height: 36px; border: none; background: transparent;
    font-size: 1.125rem; cursor: pointer; display: flex;
    align-items: center; justify-content: center;
    color: rgb(var(--color-base-text, 31, 41, 55));
    transition: background 0.15s;
  }
  .cart-item__qty-btn:hover {
    background: rgb(var(--color-base-background-2, 249, 250, 251));
  }
  .cart-item__qty-input {
    width: 40px; height: 36px; border: none;
    border-left: 1px solid rgb(var(--color-base-text, 31, 41, 55), 0.15);
    border-right: 1px solid rgb(var(--color-base-text, 31, 41, 55), 0.15);
    text-align: center; font-size: 0.875rem; font-weight: 500;
    -moz-appearance: textfield; background: transparent;
    color: rgb(var(--color-base-text, 31, 41, 55));
  }
  .cart-item__qty-input::-webkit-outer-spin-button,
  .cart-item__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none; margin: 0;
  }
  .cart-item__remove {
    border: none; background: none; cursor: pointer;
    font-size: 0.75rem; color: rgb(var(--color-base-text, 31, 41, 55), 0.45);
    text-decoration: underline; padding: 0;
  }
  .cart-item__remove:hover { color: #ef4444; }

  /* ── Line Price (desktop) ── */
  .cart-item__price {
    display: none; font-weight: 600; text-align: right; white-space: nowrap;
    color: rgb(var(--color-base-text, 31, 41, 55));
  }
  @media (min-width: 750px) {
    .cart-item__price { display: block; padding-top: 0.25rem; }
  }

  /* ── Cart Summary ── */
  .cart-page__summary {
    background: rgb(var(--color-base-background-2, 249, 250, 251));
    border-radius: 12px; padding: 1.5rem;
    position: sticky; top: 2rem;
  }
  .cart-summary__title {
    font-size: 1.25rem; font-weight: 700; margin: 0 0 1rem;
    color: rgb(var(--color-base-text, 31, 41, 55));
  }
  .cart-summary__row {
    display: flex; justify-content: space-between;
    font-size: 0.9375rem; padding: 0.375rem 0;
    color: rgb(var(--color-base-text, 31, 41, 55));
  }
  .cart-summary__row--muted {
    font-size: 0.8125rem;
    color: rgb(var(--color-base-text, 31, 41, 55), 0.55);
  }
  .cart-summary__row--total {
    font-weight: 700; font-size: 1.125rem;
    border-top: 1px solid rgb(var(--color-base-text, 31, 41, 55), 0.12);
    padding-top: 0.75rem; margin-top: 0.5rem;
  }
  .cart-summary__checkout { margin-top: 1.25rem; }
  .cart-summary__checkout-btn {
    width: 100%; min-height: 52px; font-size: 1.0625rem; font-weight: 600;
  }
  .cart-summary__continue {
    display: block; text-align: center; margin-top: 1rem;
    font-size: 0.875rem; color: rgb(var(--color-base-accent-1, 99, 102, 241));
    text-decoration: none;
  }
  .cart-summary__continue:hover { text-decoration: underline; }

  /* ── Touch targets ── */
  @media (pointer: coarse) {
    .cart-item__qty-btn { width: 44px; height: 44px; }
    .cart-item__qty-input { height: 44px; }
    .cart-summary__checkout-btn { min-height: 56px; }
  }

  /* ── Toast Notification ── */
  .cart-toast {
    position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%) translateY(100%);
    display: flex; align-items: center; gap: 0.75rem;
    padding: 0.875rem 1.25rem; border-radius: 10px;
    font-size: 0.9375rem; font-weight: 500;
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    z-index: 9999; opacity: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .cart-toast--visible { transform: translateX(-50%) translateY(0); opacity: 1; }
  .cart-toast--success {
    background: #065f46; color: #fff;
  }
  .cart-toast--error {
    background: #991b1b; color: #fff;
  }
  .cart-toast__icon { font-size: 1.125rem; }
  .cart-toast__link {
    color: #fff; text-decoration: underline; font-weight: 600;
    margin-left: 0.25rem;
  }

  /* ── Visually Hidden (a11y) ── */
  .visually-hidden {
    position: absolute !important; width: 1px !important; height: 1px !important;
    padding: 0 !important; margin: -1px !important; overflow: hidden !important;
    clip: rect(0,0,0,0) !important; white-space: nowrap !important;
    border: 0 !important;
  }
</style>
